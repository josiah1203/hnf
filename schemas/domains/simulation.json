{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummingbird.dev/hnf/v0.1/domains/simulation.json",
  "title": "HNF domain: simulation",
  "description": "Simulation domain — solver models and probes (HNF v0.1 Phase 0).",
  "type": "object",
  "additionalProperties": false,
  "required": ["domain", "version", "hnf_type", "object_id", "properties"],
  "properties": {
    "domain": { "const": "simulation" },
    "version": { "const": "0.1" },
    "hnf_type": { "type": "string", "minLength": 1, "default": "hardware.object" },
    "object_id": { "type": "string", "minLength": 1 },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "properties": {
      "type": "object",
      "additionalProperties": false,
      "required": ["models"],
      "properties": {
        "models": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/model" }
        },
        "probes": {
          "type": "array",
          "items": { "$ref": "#/$defs/probe" },
          "default": []
        }
      }
    }
  },
  "$defs": {
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["spice", "em", "fea", "mixed"]
        },
        "solver": { "type": "string" },
        "netlist_hash": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$",
          "description": "HNFT ref to SPICE/EM/FEA deck blob"
        }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "model_id", "signal"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "model_id": { "type": "string", "minLength": 1 },
        "signal": { "type": "string", "minLength": 1 }
      }
    }
  }
}
