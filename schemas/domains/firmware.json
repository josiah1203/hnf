{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummingbird.dev/hnf/v0.1/domains/firmware.json",
  "title": "HNF domain: firmware",
  "description": "Firmware domain — targets, sources, and HNFT artifacts (HNF v0.1 Phase 0).",
  "type": "object",
  "additionalProperties": false,
  "required": ["domain", "version", "hnf_type", "object_id", "properties"],
  "properties": {
    "domain": { "const": "firmware" },
    "version": { "const": "0.1" },
    "hnf_type": { "type": "string", "minLength": 1, "default": "hardware.object" },
    "object_id": { "type": "string", "minLength": 1 },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "properties": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targets"],
      "properties": {
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/target" }
        },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/source" },
          "default": []
        },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact" },
          "default": []
        }
      }
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "platform"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 },
        "board": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "language"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "language": {
          "type": "string",
          "enum": ["c", "cpp", "asm", "rust", "verilog", "python"]
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "content_hash"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "content_hash": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$",
          "description": "HNFT ref to firmware binary or hex image"
        }
      }
    }
  }
}
