{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummingbird.dev/hnf/v0.1/domains/ic_layout.json",
  "title": "HNF domain: ic_layout",
  "description": "IC layout domain — GDS layers and shapes (HNF v0.1 Phase 0).",
  "type": "object",
  "additionalProperties": false,
  "required": ["domain", "version", "hnf_type", "object_id", "properties"],
  "properties": {
    "domain": { "const": "ic_layout" },
    "version": { "const": "0.1" },
    "hnf_type": { "type": "string", "minLength": 1, "default": "hardware.object" },
    "object_id": { "type": "string", "minLength": 1 },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$",
      "description": "SHA-256 of HNFT blob (GDS/OASIS)"
    },
    "refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "properties": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layers"],
      "properties": {
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/layer" }
        },
        "shapes": {
          "type": "array",
          "items": { "$ref": "#/$defs/shape" },
          "default": []
        }
      }
    }
  },
  "$defs": {
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "layer", "datatype"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "layer": { "type": "integer", "minimum": 0 },
        "datatype": { "type": "integer", "minimum": 0 }
      }
    },
    "shape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "layer_id", "bbox"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "layer_id": { "type": "string", "minLength": 1 },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "number" }
        }
      }
    }
  }
}
