{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummingbird.dev/hnf/v0.1/domains/mechanical.json",
  "title": "HNF domain: mechanical",
  "description": "MCAD mechanical domain — semantic superset around STEP geometry blobs (ADR-0002).",
  "type": "object",
  "additionalProperties": false,
  "required": ["domain", "version", "hnf_type", "object_id", "properties"],
  "properties": {
    "domain": { "const": "mechanical" },
    "version": { "const": "0.1" },
    "hnf_type": { "type": "string", "minLength": 1, "default": "hardware.object" },
    "object_id": { "type": "string", "minLength": 1 },
    "content_hash": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$",
      "description": "SHA-256 of primary HNFT blob (STEP assembly)"
    },
    "refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "default": []
    },
    "properties": {
      "type": "object",
      "additionalProperties": false,
      "required": ["solids"],
      "properties": {
        "solids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/solid" }
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/constraint" },
          "default": []
        },
        "tolerances": {
          "type": "array",
          "items": { "$ref": "#/$defs/tolerance" },
          "default": []
        },
        "materials": {
          "type": "array",
          "items": { "$ref": "#/$defs/material_spec" },
          "default": []
        },
        "boundary_conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/boundary_condition" },
          "default": []
        },
        "notes": { "type": "string" }
      }
    }
  },
  "$defs": {
    "geometry_blob": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "content_hash"],
      "properties": {
        "format": { "type": "string", "enum": ["step", "brep", "mesh"] },
        "content_hash": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
      }
    },
    "solid": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "material": { "type": "string" },
        "volume_mm3": { "type": "number", "exclusiveMinimum": 0 },
        "geometry_blobs": {
          "type": "array",
          "items": { "$ref": "#/$defs/geometry_blob" },
          "default": []
        }
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "solid_a"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "solid_a": { "type": "string", "minLength": 1 },
        "solid_b": { "type": "string", "minLength": 1 }
      }
    },
    "tolerance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "feature_id", "tolerance_type"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "feature_id": { "type": "string", "minLength": 1 },
        "tolerance_type": { "type": "string", "minLength": 1 },
        "value_mm": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "material_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "density_kg_m3": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "boundary_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "solid_id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "solid_id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    }
  }
}
